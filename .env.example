CURSOR_API_KEY=cursor_
OPENAI_API_KEY=sk-
TELEGRAM_BOT_TOKEN=123456:ABCDEF
ALLOWED_USER_IDS=123456789

# Optional: GitHub classic PAT with "repo" scope — enables /repos picker + /repocreate
GITHUB_TOKEN=ghp_

# Optional fallback repo when you have not picked one via /repos or /repo
DEFAULT_REPO_URL=https://github.com/you/your-repo

DATA_DIR=./data

# --- Voice reply (TLDR audio after each Cursor turn; pick ONE backend) ---
# Erandroid / custom bridge: HTTP POST JSON {"text":"..."} → audio/mpeg body OR {"audio_base64":"..."}
# TTS_WEBHOOK_URL=https://your-server/tts
# TTS_WEBHOOK_BEARER=

# ElevenLabs TLDR voice (never commit real keys):
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_v3

# Or OpenAI speech (needs OPENAI_API_KEY above): alloy, cedar, sage, marin, etc.
# OPENAI_TTS_VOICE=alloy
